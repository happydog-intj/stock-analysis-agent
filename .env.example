# ================================================================
# StockAnalysisAgent 环境变量配置模板
# 复制为 .env 并填入真实值
# ================================================================

# ── 数据库 ──────────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stock_agent
DB_POOL_SIZE=10

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Claude API ──────────────────────────────────────────────────
# 申请地址：https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── 飞书机器人 Webhook ───────────────────────────────────────────
# 在飞书群 → 设置 → 机器人 → 添加机器人 → 自定义机器人 → 获取 Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# ── Reddit API ──────────────────────────────────────────────────
# 申请地址：https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── 雪球 Cookie ─────────────────────────────────────────────────
# 用浏览器登录雪球后，F12 → Application → Cookies，
# 导出为 JSON 字符串（格式：[{"name":"token","value":"xxx",...}]）
XUEQIU_COOKIES=[]

# ── 富途 OpenD ──────────────────────────────────────────────────
# 需本地安装并运行 Futu OpenD
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# ── 目标股票 ────────────────────────────────────────────────────
PRIMARY_TICKER=1860.HK

# ── 时区 ────────────────────────────────────────────────────────
TIMEZONE=Asia/Hong_Kong

# ── 日志级别 ─────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
