# ================================================================
# StockAnalysisAgent 环境变量配置模板
# 复制为 .env 并填入真实值
# ================================================================

# ── LLM 通用配置 ─────────────────────────────────────────────────
# 可选提供商：claude / qwen / kimi / glm / minimax
LLM_PROVIDER=claude
# 留空则使用各提供商默认模型（见下方注释）
LLM_MODEL=

# ── Claude（Anthropic）──────────────────────────────────────────
# 申请：https://console.anthropic.com/
# 默认模型：claude-3-5-sonnet-20241022
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── Qwen（通义千问）── LLM_PROVIDER=qwen 时使用 ────────────────
# 申请：https://dashscope.console.aliyun.com/
# 默认模型：qwen-plus  可选：qwen-max / qwen-turbo / qwen-long
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── Kimi（月之暗面）── LLM_PROVIDER=kimi 时使用 ────────────────
# 申请：https://platform.moonshot.cn/
# 默认模型：moonshot-v1-32k  可选：moonshot-v1-8k / moonshot-v1-128k
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── GLM（智谱 AI）── LLM_PROVIDER=glm 时使用 ──────────────────
# 申请：https://open.bigmodel.cn/
# 默认模型：glm-4-plus  可选：glm-4 / glm-4-air / glm-4-flash
GLM_API_KEY=xxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# ── MiniMax ── LLM_PROVIDER=minimax 时使用 ────────────────────
# 申请：https://platform.minimaxi.com/
# 默认模型：abab6.5s-chat
MINIMAX_API_KEY=xxxxxxxxxxxxxxxx
MINIMAX_GROUP_ID=xxxxxxxxxxxxxxxx

# ── 飞书机器人 Webhook ───────────────────────────────────────────
# 在飞书群 → 设置 → 机器人 → 添加机器人 → 自定义机器人 → 获取 Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# ── Reddit API ──────────────────────────────────────────────────
# 申请地址：https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── 雪球 Cookie ─────────────────────────────────────────────────
# 用浏览器登录雪球后，F12 → Application → Cookies，
# 导出为 JSON 字符串（格式：[{"name":"token","value":"xxx",...}]）
XUEQIU_COOKIES=[]

# ── 富途 OpenD ──────────────────────────────────────────────────
# 需本地安装并运行 Futu OpenD
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# ── 目标股票 ────────────────────────────────────────────────────
PRIMARY_TICKER=1860.HK

# ── 时区 ────────────────────────────────────────────────────────
TIMEZONE=Asia/Hong_Kong

# ── 日志级别 ─────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
